{"_id":"684839d4ec77df246d883b1f","application":"68428b644ba37cc929cd3d11","company":"1","tags":[{"name":"UCP Events","type":"js","sub_type":"inline","compatible_engines":["vue2","react"],"position":"head","pages":[],"_id":"6854224b9d1c39bdde4dd98d","content":"\nwindow.UCP_CUSTOM_EVENTS = ['cart.update','cart.newProduct','cart.remove','custom.view_item_plp','custom.view_item_plp_search_list','product_list.click','custom.click_recommendation','custom.banner_click','custom.sections_click','product.view'];\n\n!function(){var e=window.stelios=window.stelios||[];if(!e.initialize){if(e.invoked)window.console&&console.error&&console.error(\"Stelios snippet included twice.\");else{e.invoked=!0,e.methods=[\"track\",],e.factory=function(t){return function(){var i=Array.prototype.slice.call(arguments);return i.unshift(t),e.push(i),e}};for(var t=0;t<e.methods.length;t++){var i=e.methods[t];e[i]=e.factory(i)}e.load=function(i,o){var a=document.createElement(\"script\");a.type=\"text/javascript\",a.async=!0,a.onload=o,a.src=\"https://cdn.pixelbin.io/v2/autumn-band-3b0a0b/original/ucp-sdk/stelios/cctz0/stelios.min.js\";var r=document.getElementsByTagName(\"script\")[0];r.parentNode.insertBefore(a,r),e._loadOptions=t},e._writeKey=\"2f369baae32a9f689b53baa9d7a1e84ff8a7ca03fcd624b587f5ccad5f297db4\",e._cdn=\"https://api.cctz0.de/service/application/ccp-ingest/stream/v1.0\",e.SNIPPET_VERSION=\"4.15.3\",e.load(\"2f369baae32a9f689b53baa9d7a1e84ff8a7ca03fcd624b587f5ccad5f297db4\",function(){window.stelios=window.stelios.AnalyticsBrowser.load({writeKey:e._writeKey,cdnURL:\"https://api.cctz0.de/service/application/ccp-ingest/stream/v1.0\"},{initialPageview:false})})}}}();\n\nfunction UCP_JSON_Formatter(event= \"\", eventData={},type=\"\"){\n    let data = {};\n    if(eventData?.product){\n        data = eventData?.product ;\n    }\n    if((eventData?.products !== undefined && eventData?.products != null) && eventData?.products.length > 0) {\n        data = eventData?.products[0];\n    }\n    let extraData = eventData?.product_extra_data;\n    let userdata = {}; \n    let rrid = '';\n    let userid = '';\n    let userauth = '';\n    let productJson = {};\n    let cart_add_detail=[];\n    let l1_category = \"\";\n    let l2_category = \"\";\n    let l3_category = \"\";\n    let l4_category = \"\";\n    let l5_category = \"\";\n    let l1_id = \"\";\n    let l2_id = \"\";\n    let l3_id = \"\";\n    let l4_id = \"\";\n    let l5_id = \"\";\n    let cartid=0;\n    let cartinfo={};\n    let verticalCode = \"\";\n    let imageUrl = \"\";\n    let price = 0;\n    let dimension_data = {};\n    if(eventData?.cart_id){\n        cartid = eventData?.cart_id;\n    }\n    // if(action=='remove' && prodqty==0){\n    //   prodqty=1;\n    // }\n    if(window.FPI?.state?.user?._data){\n        userdata = window.FPI?.state?.user?._data?.user ? window.FPI?.state?.user?._data?.user : {}; \n        rrid= userdata.rr_id ? userdata.rr_id : '';\n        userid= userdata.user_id ? userdata.user_id : '';\n        userauth = localStorage.getItem('userauth') ? localStorage.getItem('userauth') : '';\n    }\n    // if(data != null && userdata != '' && rrid != '' && userid != '' && userauth != ''){\n        \n        let product_id = data?.uid ? data.uid.toString() : '';\n        if(data?.categories){\n            l1_category = ((data?.categories[0]?.name.split('::')).length > 0) ? ((data.categories[0].name.split('::')[0] != undefined && data.categories[0].name.split('::')[0] != null) ? data.categories[0].name.split('::')[0] : \"\"): \"\";\n            l2_category = ((data?.categories[0].name.split('::')).length > 0) ? ((data.categories[0].name.split('::')[1] != undefined && data.categories[0].name.split('::')[1] != null) ? data.categories[0].name.split('::')[1] : \"\"): \"\";\n            l3_category = ((data?.categories[0].name.split('::')).length > 1) ? ((data.categories[0].name.split('::')[2] != undefined && data.categories[0].name.split('::')[2] != null) ? data.categories[0].name.split('::')[2] : \"\"): \"\";\n            l4_category = ((data?.categories[0].name.split('::')).length > 2) ? ((data.categories[0].name.split('::')[3] != undefined && data.categories[0].name.split('::')[3] != null) ? data.categories[0].name.split('::')[3] : \"\"): \"\";\n            l5_category = ((data?.categories[0].name.split('::')).length > 3) ? ((data.categories[0].name.split('::')[4] != undefined && data.categories[0].name.split('::')[4] != null) ? data.categories[0].name.split('::')[4] : \"\"): \"\";\n        }\n        if(type == \"Product Viewed\") {\n            if(FPI?.state?.product?._data?.product){\n                if(FPI?.state?.product?._data?.product?.uid == product_id){\n                    if(FPI?.state?.product?._data?.product?.category_map){\n                        l2_id = ((FPI?.state?.product?._data?.product?.category_map?.l1 != undefined && FPI?.state?.product?._data?.product?.category_map?.l1 != null)) ? FPI?.state?.product?._data?.product?.category_map?.l1?.uid : \"\";\n                        l3_id = ((FPI?.state?.product?._data?.product?.category_map?.l2 != undefined && FPI?.state?.product?._data?.product?.category_map?.l2 != null)) ? FPI?.state?.product?._data?.product?.category_map?.l2?.uid : \"\";\n                        l4_id = ((FPI?.state?.product?._data?.product?.category_map?.l3 != undefined && FPI?.state?.product?._data?.product?.category_map?.l3 != null)) ? FPI?.state?.product?._data?.product?.category_map?.l3?.uid : \"\";\n                        l5_id = ((FPI?.state?.product?._data?.product?.category_map?.l4 != undefined && FPI?.state?.product?._data?.product?.category_map?.l4 != null)) ? FPI?.state?.product?._data?.product?.category_map?.l4?.uid : \"\";\n                    }\n                    if(FPI?.state?.product?._data?.product?.department){\n                        l1_id = FPI?.state?.product?._data?.product?.department?.uid;\n                    }\n                    if(FPI?.state?.product?._data?.product){\n                        if(FPI?.state?.product?._data?.product?.medias.length > 0){\n                            imageUrl = FPI?.state?.product?._data?.product?.medias[0].url || \"\";\n                        }\n                    }\n                }\n            }\n        }\n        if(data?.attributes?.multi_categories){\n            l1_id = data?.attributes?.multi_categories[0].department ? data.attributes.multi_categories[0].department.toString() : '';\n            l2_id = data?.attributes?.multi_categories[0].l1 ? data.attributes.multi_categories[0].l1.toString() : '';\n            l3_id = data?.attributes?.multi_categories[0].l2 ? data.attributes.multi_categories[0].l2.toString() : '';\n            l4_id = data?.attributes?.multi_categories[0].l3 ? data.attributes.multi_categories[0].l3.toString() : '';\n            l5_id = data?.attributes?.multi_categories[0].l4 ? data.attributes.multi_categories[0].l4.toString() : '';\n        }\n\n        if(data?.category && data?.category?.name){ // cart data\n            l1_category = ((data?.category?.name.split('::')).length > 0) ? ((data?.category?.name.split('::')[0] != undefined && data?.category?.name.split('::')[0] != null) ? data?.category?.name.split('::')[0] : \"\"): \"\";\n            l2_category = ((data?.category?.name.split('::')).length > 0) ? ((data?.category?.name.split('::')[1] != undefined && data?.category?.name.split('::')[1] != null) ? data?.category?.name.split('::')[1] : \"\"): \"\";\n            l3_category = ((data?.category.name.split('::')).length > 1) ? ((data?.category?.name.split('::')[2] != undefined && data?.category?.name.split('::')[2] != null) ? data?.category?.name.split('::')[2] : \"\"): \"\";\n            l4_category = ((data?.category.name.split('::')).length > 2) ? ((data?.category?.name.split('::')[3] != undefined && data?.category?.name.split('::')[3] != null) ? data?.category?.name.split('::')[3] : \"\"): \"\";\n            l5_category = ((data?.category.name.split('::')).length > 3) ? ((data?.category?.name.split('::')[4] != undefined && data?.category?.name.split('::')[4] != null) ? data?.category?.name.split('::')[4] : \"\"): \"\";\n        }\n\n        if(window.FPI?.state?.product?.selectedArticle?._data?.items.length > 0){\n            if(window.FPI?.state?.product?.selectedArticle?._data?.items[0]?._custom_json?.attributes?.classification?.category.length > 0){\n                let categories = window.FPI?.state?.product?.selectedArticle?._data?.items[0]?._custom_json?.attributes?.classification?.category;\n                if(categories !== undefined && categories != null){\n                    l1_category =  (categories.length > 1) ? (categories[1]?.name || \"\") : \"\";\n                    l2_category =  (categories.length > 2) ? (categories[2]?.name || \"\") : \"\";\n                    l3_category =  (categories.length > 3) ? (categories[3]?.name || \"\") : \"\";\n                    l4_category =  (categories.length > 4) ? (categories[4]?.name || \"\") : \"\";\n                    l5_category =  (categories.length > 5) ? (categories[5]?.name || \"\") : \"\";\n    \n                    l1_id = (categories.length > 1) ? (categories[1]?.source_id || \"\") : \"\";\n                    l2_id = (categories.length > 2) ? (categories[2]?.source_id || \"\") : \"\";\n                    l3_id = (categories.length > 3) ? (categories[3]?.source_id || \"\") : \"\";\n                    l4_id = (categories.length > 4) ? (categories[4]?.source_id || \"\") : \"\";\n                    l5_id = (categories.length > 5) ? (categories[5]?.source_id || \"\") : \"\";\n                }\n            }\n        }\n\n        let brand = (data.brand) ? data.brand.name : data.brand_name;\n        let brand_id = (data.brand.uid || '').toString();\n\n        let click_source = extraData?.click_source || '';\n\n        let sku_raw = data?.item_code ? data?.item_code.toString() : '';\n\n        let productName = data.name || '';\n        if(data?.price?.max){\n            price = Number(data?.price?.max.toFixed(2)) ; \n        }\n        if(data?.price?.effective){\n            if(data?.price?.effective?.max){\n                price = Number(data?.price?.effective?.max.toFixed(2)) ; \n            } else {\n                price = Number(data?.price?.effective.toFixed(2)) ; \n            }\n        }\n\n        if(data?.price_per_unit?.converted?.effective){\n            if(data?.price_per_unit?.converted?.effective?.max){\n                price = Number(data?.price_per_unit?.converted?.effective?.max.toFixed(2)) ; \n            } else {\n                price = Number(data?.price_per_unit?.converted?.effective.toFixed(2)) ; \n            }\n        }\n\n        let currencyCode = data?.price?.effective?.currency_code || \"INR\";\n\n        if(data?.price?.currency_code){\n            currencyCode = data?.price?.currency_code || \"INR\";\n        }\n\n        let productUrl = '/product/'+data.slug;\n        if(data?.source_url){\n            productUrl = data?.source_url;\n        }\n        if(data?.attributes){\n            verticalCode  = data?.attributes['vertical-code'] || '';\n        }\n\n        if(window.FPI?.state?.product?.selectedArticle?._data?.items.length > 0){\n            if(window.FPI?.state?.product?.selectedArticle?._data?.items[0]?._custom_json?.vertical_code){\n                verticalCode = window.FPI?.state?.product?.selectedArticle?._data?.items[0]?._custom_json?.vertical_code || \"\";\n            }\n        }\n        if(type == \"Product Viewed\") {\n            if(FPI?.state?.product?._data?.product){\n                if(FPI?.state?.product?._data?.product?.uid == product_id){\n                    if(FPI?.state?.product?._data?.product?.attributes){\n                        var fpi_attr_entries = Object.entries(FPI?.state?.product?._data?.product?.attributes);\n                        fpi_attr_entries.map(([fpi_attrIndex, fpi_attrItem] = attr_entry) => {\n                            if(fpi_attrIndex == \"vertical-code\"){\n                                verticalCode = fpi_attrItem;\n                            }\n                        });\n                    }\n                }\n            }\n        }\n        if((data?.medias != undefined && data?.medias != null) && data?.medias.length > 0){\n            imageUrl = data?.medias[0]['url'] ? data.medias[0]['url'] : '';\n        }\n        if(window.FPI?.state?.product?.selectedArticle?._data?.items.length > 0){\n            if(window.FPI?.state?.product?.selectedArticle?._data?.items[0]?._custom_json?.attributes?.image_groups['Product Images']?.images.length > 0){\n                imageUrl = window.FPI?.state?.product?.selectedArticle?._data?.items[0]?._custom_json?.attributes?.image_groups['Product Images']?.images[0]?.original || \"\";\n            }\n        }\n\n        productJson = {\n            \"external_ids\":[\n                {\n                \"type\": \"rr_id\",\n                \"id\": rrid\n                }\n            ],\n            \"application_ids\":[\n                {\n                \"type\": \"jiomart_id\",\n                \"id\": userid\n                }\n            ],\n            \"meta\": {\n                \"session_id\": userauth\n                // \"widget_id\": \"\",\n                // \"widget_source_type\": listname+\"|mylist\"\n            },\n            \"click_source\": click_source,\n            \"product_id\": product_id,\n            \"product_name\": productName,\n            \"sku\": sku_raw,\n            \"l1_category\": l1_category,//productInfo?.categorylevel?.level1?.length > 0 ? productInfo.categorylevel.level1[0] : '',\n            \"l1_category_id\": l1_id,\n            \"l2_category\": l2_category,\n            \"l2_category_id\": l2_id,\n            \"l3_category\": l3_category,\n            \"l3_category_id\": l3_id,\n            \"l4_category\": l4_category,\n            \"l4_category_id\": l4_id,\n            \"l5_category\": l5_category,\n            \"l5_category_id\": l5_id,\n            \"brand\": brand,\n            \"brand_id\": brand_id,\n            \"quantity\": 1,\n            \"price\": price,\n            \"value\": price, // need to update Number(data.price.marked.max.toFixed(2))\n            \"currency\": currencyCode,\n            \"url\": productUrl,\n            \"verticalcode\": verticalCode,\n            \"img_url\": imageUrl //productInfo?.image?(productInfo.image):Configs.ANG_URL+\"/images/product/original/\"+productInfo.product_image_path\n        };\n        if(cartid){\n            productJson.cart_id = cartid;\n        }\n    // }\n    return productJson;\n}\nfunction steliosContext(eventtype=''){\n      let contextVar={};\n      /*let campaignObj = {};\n      campaignObj['name'] = this.cookieService.get('_rsCampaign') || '';\n      campaignObj['source'] = this.cookieService.get('_rsSource') || '';\n      campaignObj['medium'] = this.cookieService.get('_rsMedium') || '';\n      campaignObj['content'] = \"\";\n      if(localStorage.getItem(\"console_log_enable\") == \"1\"){\n          console.log(campaignObj);\n      }\n      if(campaignObj['name']!=''){\n        contextVar['campaign']=campaignObj;\n      }*/\n      contextVar['channel'] = 'web';\n      let device = (/android|webos|iphone|ipad|ipod|blackberry|iemobile|opera mini/i.test(navigator.userAgent.toLowerCase()));\n      if (localStorage.getItem('nms_refer_lite')) {\n        if((/iPad|iPhone|iPod/.test(window.navigator.userAgent))){\n          contextVar['channel'] = 'IOS';\n        }else{\n          contextVar['channel'] = 'Android';\n        }\n      }else if (device) {\n        contextVar['channel'] = 'msite';\n      }\n      if(localStorage.getItem('console_log_enable')==\"1\"){\n        console.log(\"Stelios - Context\",contextVar);\n      }\n      return contextVar;\n}"},{"name":"RAC login","type":"js","sub_type":"inline","compatible_engines":["vue2","react"],"position":"head","pages":[],"_id":"68d3a7e719ca9ec7f4a0662b","content":"window.ucpRetailAuth={openLogin:function(i){console.log(\"in UCP login\");let t,l=`/ext/retail-auth/ui/login?application_id=${window.APP_DATA.applicationID}&return_ui_url=${i?encodeURIComponent(i):encodeURIComponent(window.location.href)}`;window.location.replace(l)},openProfile:function(i){let t,l=`/ext/retail-auth/ui/profile-redirect?application_id=${window.APP_DATA.applicationID}&return_ui_url=${i?encodeURIComponent(i):encodeURIComponent(window.location.href)}`;window.location.replace(l)}};\n"},{"name":"ReactExt","type":"js","sub_type":"inline","compatible_engines":["react"],"position":"head","pages":[],"_id":"68dbbeac2a8e0cef77cefe12","content":"const FPI_EXT_FUNC = () => { let events = {}; let unregisteredEmits = []; let id = 0; let HOOKS = { CREATED: 'created', MOUNTED: 'mounted', UPDATED: 'updated', DESTROYED: 'destroyed', WATCH_ROUTE: 'watch.route', }; return { _getSanitizedEH(eventHandlers) { const allHooks = Object.values(HOOKS); return Object.entries(eventHandlers).reduce((ret, [k, v]) => { if (k == 'watch') { ret[k] = v; } else if (!allHooks.includes(k)) { console.warn(`${k} is not a valid hook for FPI.extension.register#hooks`); } else if (typeof v !== 'function') { console.error(`${k} should be a function FPI.extension.register#${k}`); } else { ret[k] = v; } return ret; }, {}); }, emit: function (eventName, el, ...data) { const [hook, watcher] = eventName.split('.'); let callbackExists = false; Object.entries(events).forEach(([target, events]) => { const targetElement = (el instanceof Element && el.matches(target) && el) || el.querySelector(target); if (!targetElement) { return; } callbackExists = true; if (events[hook]) { if (watcher) { events[hook][watcher](targetElement, ...data); } else { events[hook](targetElement, ...data); } } }); if (!callbackExists) { unregisteredEmits = [...(unregisteredEmits || []), { eventName, el, data, },]; } }, register: function (target, eventHandlers) { const sanitizedEH = this._getSanitizedEH(eventHandlers); if (!events[target]) { events[target] = {} } events[target] = { ...sanitizedEH }; if (unregisteredEmits.length) { unregisteredEmits = unregisteredEmits.filter((state) => { const { eventName, el, data } = state; if (!!el.querySelector(target)) { this.emit(eventName, el, ...data); return false; } return true; }); } }, } }; window.FPI_EXT = FPI_EXT_FUNC();FPI_EXT.event = FPI.event;\n "},{"name":"Haptik Test","type":"js","sub_type":"inline","compatible_engines":["vue2","react"],"position":"head","pages":[{"page_slug":"faq","type":"system"},{"page_slug":"login","type":"system"},{"page_slug":"about-us","type":"system"}],"_id":"68e3eadeb07563746b55ab98","content":"(() => {\n  let config;\n  let user;\n  let isEnabled = true;\n  let isUserLoggedIn = false;\n  let shouldOpenBeautyAdvisor = false;\n  console.log(window.fpi, 'check fpi');\n\n  function setupHaptik() {\n/**    \nfetch('/ext/haptik/application/api/v1.0/application', {\n      headers: {\n        // TODO: remove this header as this is only required for bypassing localtunnel screen in development\n        'Bypass-Tunnel-Reminder': true,\n      },\n    })\n      .then((response) => response.json())\n      .then((json) => {\n        config = json.data.config;\n        isEnabled = config.is_enabled;\n        //TODO:(Naman): Needs to be removed after qa pass\n        // isUserLoggedIn = !!window.FPI?.state?.user?._data?.user;\n        const isIOS = !!window.webkit;\n        const isAndroid = !!window.__fyndKit;\n        const isMobile = isIOS || isAndroid;\n\n        console.log('isMobile, isIOS, isAndroid', isMobile, isIOS, isAndroid);\n\n        if (isEnabled && !isMobile) {\n          console.log('inside enabled ');\n          window.haptikInitSettings = {\n            'business-id': config.haptik.business_id,\n            'client-id': config.haptik.client_id,\n            'base-url': config.haptik.base_url,\n            'custom-css':\n              config.extension_css_url ||\n              `${config.extension_base_url}/haptik-web.css`,\n          };\n          const script = document.createElement('script');\n          script.id = 'haptik-api-toolassets';\n          script.src =\n            'https://toolassets.haptikapi.com/platform/javascript-xdk/production/loader.js';\n          script.async = true;\n          document.body.appendChild(script);\n          script.onload = () => {\n            console.log('Haptik script added');\n          };\n          return;\n        }\n        console.log('Haptik disabled on this channel');\n\n        return;\n      })\n      .catch((error) => {\n        console.log('Something went wrong while fetching haptik config', error);\n      });\n  }\n\n  function signupInHaptik() {\n    if (!user || !user.phone_numbers || !user.emails || !window.HaptikSDK)\n      return;\n\n    let phoneNumber;\n    const phoneNumberData = user.phone_numbers.find(\n      (phoneNumber) => phoneNumber && phoneNumber.primary\n    );\n    if (phoneNumberData && phoneNumberData.phone) {\n      phoneNumber = phoneNumberData.phone;\n    }\n\n    let email;\n    const emailData = user.emails.find((email) => email && email.primary);\n    if (emailData && emailData.email) {\n      email = emailData.email;\n    }\n\n    window.HaptikSDK.signup(\n      {\n        username: `${user.first_name} ${user.last_name}`,\n        auth_id: user.user_id,\n        auth_code: phoneNumber,\n        mobile_no: phoneNumber,\n        email,\n      },\n      function (success, error) {\n        if (success) {\n          chatBotDefaultOpen();\n          console.log('HAPTIK SIGNUP REQUEST SUCCEEDED!');\n        } else {\n          console.log('HAPTIK SIGNUP REQUEST ERROR:', error);\n        }\n      }\n    );\n\n    sendSilentMessage();\n    checkChatbotVisibility();\n  }\n\n  function sendSilentMessage() {\n    console.log('shouldOpenBeautyAdvisor', shouldOpenBeautyAdvisor);\n\n    if (window.location.hostname.includes('tira')) {\n      if (shouldOpenBeautyAdvisor) {\n        window.HaptikSDK.launchMessage(\n          'Beauty Advisor',\n          () => {\n            console.log('Successfully sent the beauty advisor launch message');\n            window.HaptikSDK.show();\n          },\n          true\n        );\n      } else {\n        window.HaptikSDK.launchMessage(\n          \"Let's Chat\",\n          () => {\n            console.log('Successfully sent the launch message');\n          },\n          true,\n          true,\n          true\n        );\n      }\n    }\n  }\n\n  function signOutHaptik() {\n    console.log('Logging out of Haptik...');\n    if (!window.HaptikSDK) {\n      console.log('HaptikSDK not found in global, exiting...');\n      return;\n    }\n\n    window.HaptikSDK.logout(() => {\n      console.log('Successfully logged out from Haptik');\n    });\n  }\n\n  function chatbotQueryParam() {\n    const urlParams = new URLSearchParams(window.location.search);\n    if (urlParams.get('chatbot_open') === 'true') {\n      return true;\n    }\n    return false;\n  }\n\n  function chatBotDefaultOpen() {\n    const isChatbotQueryParam = chatbotQueryParam();\n    if (isChatbotQueryParam && window.HaptikSDK) {\n      shouldOpenBeautyAdvisor = true;\n      sendSilentMessage();\n    }\n  }\n\n  function handleChatbotLink() {\n    const isChatbotQueryParam = chatbotQueryParam();\n    const isLoginUrl = window.location.href.includes('/auth/login');\n    if (isChatbotQueryParam && !isLoginUrl) {\n      window.location.href =\n        '/auth/login?redirectUrl=' +\n        encodeURIComponent('/' + window.location.search);\n    }\n  }\n\n  function checkChatbotVisibility() {\n    const haptikBot = document.querySelector('#haptik-xdk-wrapper');\n    const haptikContainer = document.querySelector('#haptik-xdk-container');\n    if (!haptikBot || !window.FPI) return;\n\n    // TODO: reference for FPI utility support https://gofynd.atlassian.net/browse/FPCO-4572\n    const action = convertUrlToAction(window.location.pathname);\n    let pages = [];\n    if (config && config.injection && config.injection.pages) {\n      pages = config.injection.pages;\n    }\n    if (\n      pages.find(\n        (page) =>\n          page.page_type === action.page.type ||\n          (page.page_type === 'profile' && action.page.type === 'profile-basic')\n      )\n    ) {\n      haptikBot.style.opacity = 1;\n      haptikBot.style.pointerEvents = 'auto';\n      haptikContainer.style.display = 'block';\n    } else {\n      if (window.HaptikSDK) window.HaptikSDK.hide();\n      haptikBot.style.opacity = 0;\n      haptikBot.style.pointerEvents = 'none';\n    }\n  }\n\n  if (window.FPI) {\n    window.FPI.event.on('haptik.aef', (payload) => {\n      console.log('haptik.aef event fired');\n\n      const {\n        context: { source },\n        envelope: { name },\n      } = payload;\n\n      if (source.includes('tira') && name === 'beauty-advisor-intent') {\n        console.log(\n          'shouldOpenBeautyAdvisor set to true; previous value',\n          shouldOpenBeautyAdvisor\n        );\n        shouldOpenBeautyAdvisor = true;\n        if (window.HaptikSDK) {\n          console.log('window.HaptikSDK found, sending silent message');\n          sendSilentMessage();\n        }\n      }\n    });\n    //This is for Vue\n    if (Object.keys(window?.FPI?.state)?.length) {\n      window.FPI.state.user.subscribe((data) => {\n        if (!data || !data.user) {\n          handleChatbotLink();\n          return;\n        }\n        user = data.user;\n        if (user.active) {\n          setupHaptik();\n        }\n        signupInHaptik();\n      });\n    } else {\n      //This is for react. wait until fpi is populated\n      const fpiInterval = setInterval(() => {\n        if (window.fpi) {\n          clearInterval(fpiInterval);\n          fpi.observeStore(fpi.getters.USER_DATA, (data) => {\n            if (!data || !data.user) {\n              handleChatbotLink();\n              return;\n            }\n            user = data.user;\n            if (user.active) {\n              setupHaptik();\n            }\n            signupInHaptik();\n          });\n        }\n      }, 200);\n      // unsubscribe();\n    }\n\n    // TODO(pandey): this adds the event listener twice\n    window.FPI.event.on('user.logout', () => {\n      signOutHaptik();\n    });\n  }\n\n  document.addEventListener('haptik_sdk', signupInHaptik);\n  window.addEventListener('locationchange', checkChatbotVisibility);\n  window.addEventListener('hashchange', checkChatbotVisibility);\n})();\n\n// Setup location change event\n(function () {\n  var pushState = history.pushState;\n  var replaceState = history.replaceState;\n\n  history.pushState = function () {\n    pushState.apply(history, arguments);\n    //TODO:(Naman) : we don't require this push state - further validation required\n    window.dispatchEvent(new Event('pushstate'));\n    window.dispatchEvent(new Event('locationchange'));\n  };\n\n  //TODO:(Naman) : we don't require this replace state - further validation required\n  history.replaceState = function () {\n    replaceState.apply(history, arguments);\n    window.dispatchEvent(new Event('replacestate'));\n    window.dispatchEvent(new Event('locationchange'));\n  };\n\n  window.addEventListener('popstate', function () {\n    window.dispatchEvent(new Event('locationchange'));\n  });\n})();\n\nfunction convertUrlToAction(url) {\n  if (url) {\n    const path = trimChar(url);\n    const query = getQuery(path);\n    let pathname;\n    try {\n      pathname = new URL(path).pathname;\n    } catch (e) {\n      pathname = path.split('?')[0];\n    }\n    const allNavigations = Object.assign({}, NAVIGATORS);\n    const typeLink = {};\n    for (nav in allNavigations) {\n      let { link, params } = allNavigations[nav];\n      typeLink[link] = nav;\n      if (params) {\n        params.forEach((param) => {\n          if (param.required == false) {\n            let modifiedLink = link.slice(0, link.indexOf(param.key) - 1);\n            typeLink[modifiedLink] = nav;\n          }\n        });\n      }\n    }\n    const allLinks = Object.keys(typeLink);\n    allLinks.sort(function (a, b) {\n      return b.length - a.length;\n    });\n    const bestMatchingLink = findBestMatchingLink(allLinks, pathname);\n    const closestMatchingNavLink = Object.keys(typeLink).find((pageType) => {\n      return trimChar(pageType) === bestMatchingLink.value;\n    });\n    const closestMatchingNavKey = typeLink[closestMatchingNavLink] || 'home';\n    // if it is custom theme link url should be in query object, also we will grab our main link from this url field in convertActionToUrl\n    if (closestMatchingNavLink === NAVIGATORS.custom.link) {\n      return {\n        type: 'page',\n        page: {\n          type: closestMatchingNavKey,\n          query: {\n            url: [url.split('?')[0]],\n            ...query,\n          },\n          params: bestMatchingLink.params,\n        },\n      };\n    }\n    return {\n      type: 'page',\n      page: {\n        type: closestMatchingNavKey,\n        query: query,\n        params: bestMatchingLink.params,\n      },\n    };\n  } else {\n    return {\n      type: 'page',\n      page: {\n        type: 'home',\n        query: {},\n        params: {},\n      },\n    };\n  }\n}\n\nconst SLUG_DELIMETER = ':::';\n\nconst getQuery = (path) => {\n  let parseUrl = path.split('?');\n  if (parseUrl.length > 1) {\n    const searchParams = new URLSearchParams(parseUrl[1]);\n    let queryResult = {};\n    for (let item of searchParams) {\n      let key = item[0],\n        value = item[1];\n\n      queryResult[key] = queryResult[key]\n        ? [...queryResult[key], value]\n        : [value];\n    }\n    return queryResult;\n  }\n  return {};\n};\n\nconst trimChar = (string = '', charToRemove = '/') => {\n  while (string.charAt(0) == charToRemove) {\n    string = string.substring(1);\n  }\n\n  while (string.charAt(string.length - 1) == charToRemove) {\n    string = string.substring(0, string.length - 1);\n  }\n\n  return string;\n};\n\nconst findBestMatchingLink = (allLinks = [], pathname = '/') => {\n  let bestMatch = { value: '', params: {} };\n  pathname = trimChar(pathname); // -> product/test-product-tag/reviews\n  for (let i = 0; i < allLinks.length; i++) {\n    let link = trimChar(allLinks[i]); // -> product/:slug/add-reviews\n\n    const firstLinkMatch = trimChar(link).split('/')[0];\n    const firstPathMatch = trimChar(pathname).split('/')[0];\n    // atleast first string from path should match, if you don't add this condition then it will give link 'c' for 'collection' path name\n    if (\n      new RegExp(`^${trimChar(link)}`).test(pathname) &&\n      firstLinkMatch.length === firstPathMatch.length\n    ) {\n      bestMatch.value = link;\n      break;\n    }\n    const linkArr = link.split('/'); // -> [ 'product', ':slug', 'add-reviews' ]\n    const pathArr = pathname.split('/'); // -> [ 'product', 'test-product-tag', 'reviews' ]\n    if (linkArr.length === pathArr.length) {\n      // some match\n      let j;\n      bestMatch = { value: '', params: {} };\n      for (j = 0; j < linkArr.length; ++j) {\n        if (linkArr[j].startsWith(':')) {\n          // this will be :slug & test-slug\n          let arrParams = [];\n          if (pathArr[j].includes(SLUG_DELIMETER)) {\n            // if link container multiple path params eg test-slug--test-slug-123\n            arrParams = pathArr[j].split(SLUG_DELIMETER); // split it into array\n          } else arrParams = [pathArr[j]]; // else assign\n          if (bestMatch.params[linkArr[j].slice(1)]) {\n            // if params is already present in best match object spread new params\n            arrParams = [\n              ...bestMatch.params[linkArr[j].slice(1)],\n              ...arrParams,\n            ];\n          }\n          bestMatch.params[linkArr[j].slice(1)] = arrParams; // else assign\n        } else if (linkArr[j] !== pathArr[j]) break; // if path and link params not match and are not :slug type break and move to next link\n      }\n      if (j === linkArr.length) {\n        // if all paths match and j is not 0 coz 'about-us' & 'notification' have same length and in that case j will be 0. This type of matching is handled in Regex on line #100\n        bestMatch.value = link;\n        break;\n      }\n    }\n  }\n  return bestMatch;\n};\n\nconst NAVIGATORS = {\n  'about-us': {\n    name: 'About Us',\n    link: '/about-us',\n  },\n  addresses: {\n    name: 'Saved Addresses',\n    link: '/profile/address',\n  },\n  blog: {\n    name: 'Blog',\n    link: '/blog/:slug',\n    params: [\n      {\n        key: 'slug',\n        required: false,\n      },\n    ],\n  },\n  brands: {\n    name: 'Brands',\n    link: '/brands/:department',\n    params: [\n      {\n        key: 'department',\n        required: false,\n      },\n    ],\n  },\n  cards: {\n    name: 'Saved Cards',\n    link: '/profile/my-cards',\n  },\n  cart: {\n    name: 'Cart',\n    link: '/cart/bag/',\n  },\n  categories: {\n    name: 'Categories',\n    link: '/categories/:department',\n    params: [\n      {\n        key: 'department',\n        required: false,\n      },\n    ],\n  },\n  brand: {\n    name: 'Brand',\n    link: '/brand/:slug',\n    params: [\n      {\n        key: 'slug',\n        required: true,\n      },\n    ],\n  },\n  category: {\n    name: 'Category',\n    link: '/category/:slug',\n    params: [\n      {\n        key: 'slug',\n        required: true,\n      },\n    ],\n  },\n  collection: {\n    name: 'Collection',\n    link: '/collection/:slug',\n    params: [\n      {\n        key: 'slug',\n        required: true,\n      },\n    ],\n  },\n  collections: {\n    name: 'Collections',\n    link: '/collections/',\n  },\n  'contact-us': {\n    name: 'Contact Us',\n    link: '/contact-us/',\n  },\n  external: {\n    name: 'External Link',\n    link: '/external/',\n    query: [\n      {\n        key: 'url',\n        required: true,\n      },\n    ],\n  },\n  custom: {\n    name: 'Custom theme link',\n    link: '/c/',\n    query: [\n      {\n        key: 'url',\n        required: true,\n      },\n    ],\n  },\n  faq: {\n    name: 'FAQ',\n    link: '/faq',\n  },\n  freshchat: {\n    name: 'Chat by Freshchat',\n    link: '/freshchat',\n  },\n  home: {\n    name: 'Home',\n    link: '/',\n  },\n  'notification-settings': {\n    name: 'Notification Settings',\n    link: '/notification-settings',\n  },\n  orders: {\n    name: 'Orders',\n    link: '/profile/orders',\n  },\n  page: {\n    name: 'Page',\n    link: '/page/:slug',\n    params: [\n      {\n        key: 'slug',\n        required: true,\n      },\n    ],\n  },\n  policy: {\n    name: 'Privacy Policy',\n    link: '/privacy-policy',\n  },\n  product: {\n    name: 'Product',\n    link: '/product/:slug',\n    params: [\n      {\n        key: 'slug',\n        required: true,\n      },\n    ],\n  },\n  'product-request': {\n    name: 'Product Request',\n    link: '/product-request/',\n  },\n  products: {\n    name: 'Products',\n    link: '/products/',\n  },\n  profile: {\n    name: 'Profile',\n    link: '/profile',\n  },\n  'profile-order-shipment': {\n    name: 'profile orders shipment',\n    link: '/profile/orders/shipment/:shipmentid',\n    params: [\n      {\n        key: 'shipmentid',\n        required: true,\n      },\n    ],\n  },\n  'profile-basic': {\n    name: 'Basic Profile',\n    link: '/profile/details',\n  },\n  'profile-company': {\n    name: 'Profile Company',\n    link: '/profile/company',\n  },\n  'profile-emails': {\n    name: 'Profile Emails',\n    link: '/profile/email',\n  },\n  'profile-phones': {\n    name: 'Profile Phones',\n    link: '/profile/phone',\n  },\n  'rate-us': {\n    name: 'Rate Us',\n    link: '/rate-us',\n  },\n  'refer-earn': {\n    name: 'Refer & Earn',\n    link: '/profile/refer-earn',\n  },\n  settings: {\n    name: 'Settings',\n    link: '/setting/currency',\n  },\n  'shared-cart': {\n    name: 'Shared Cart',\n    link: '/shared-cart/:token',\n    params: [\n      {\n        key: 'token',\n        required: true,\n      },\n    ],\n  },\n  tnc: {\n    name: 'Terms and Conditions',\n    link: '/terms-and-conditions',\n  },\n  'track-order': {\n    name: 'Track Order',\n    link: '/order-tracking/:orderId',\n    params: [\n      {\n        key: 'orderId',\n        required: false,\n      },\n    ],\n  },\n  wishlist: {\n    name: 'Wishlist',\n    link: '/wishlist/',\n  },\n  sections: {\n    name: 'Sections',\n    link: '/sections/:group',\n    params: [\n      {\n        key: 'group',\n        required: true,\n      },\n    ],\n  },\n  form: {\n    name: 'Form',\n    link: '/form/:slug',\n    params: [\n      {\n        key: 'slug',\n        required: true,\n      },\n    ],\n  },\n  'cart-delivery': {\n    name: 'Cart Delivery',\n    link: '/cart/delivery',\n  },\n  'cart-payment': {\n    name: 'Cart Payment Information',\n    link: '/cart/payment-info',\n  },\n  'cart-review': {\n    name: 'Cart Order Review',\n    link: '/cart/order-review',\n  },\n  login: {\n    name: 'Login',\n    link: '/auth/login',\n  },\n  register: {\n    name: 'Register',\n    link: '/auth/register',\n  },\n  'shipping-policy': {\n    name: 'Shipping policy',\n    link: '/shipping-policy',\n  },\n  'return-policy': {\n    name: 'Return policy',\n    link: '/return-policy',\n  },\n  'order-status': {\n    name: 'Order status',\n    link: '/cart/order-status',\n  },\n  'locate-us': {\n    name: 'Locate us',\n    link: '/locate-us',\n  },\n};\n**/"},{"name":"How to buy on Jiomart","type":"js","sub_type":"inline","compatible_engines":["vue2","react"],"position":"body-bottom","pages":[{"page_slug":"page","type":"system"}],"_id":"68eca28d982adbcdd2ba5352","content":"const accSingleTriggers = document.querySelectorAll('.js-acc-single-trigger');\naccSingleTriggers.forEach(trigger => trigger.addEventListener('click', toggleAccordion));\n\nfunction toggleAccordion() {\n  const items = document.querySelectorAll('.js-acc-item');\n  const thisItem = this.parentNode;\n\n  items.forEach(item => {\n    if (thisItem == item) {\n      thisItem.classList.toggle('is-open');\n      return;\n    }\n    item.classList.remove('is-open');\n  });\n}\n"},{"name":"Smart App Banner injection script","type":"js","sub_type":"external","compatible_engines":["vue2","react"],"position":"body-bottom","attributes":{"id":"68428b644ba37cc929cd3d11"},"pages":[],"__source":{"type":"extension","id":"6842bc4f2f22ab89c8887df9"},"_id":"68edf7b610fc19b2edace171","url":"https://smart-app-banners.extensions.uat.jiomartjcp.com/bindings/smart-app-banner/smart-app-banner.umd.js"},{"name":"retail-redirection","type":"js","sub_type":"inline","compatible_engines":["vue2","react"],"position":"body-bottom","pages":[],"__source":{"type":"extension","id":"6842a6172f22ab89c8887b85"},"_id":"69304de9ecdd4b7fd95d4ba9","content":"\nwindow.ucpRetailAuth = {\n    openLogin: function (redirect_url) {\n        let app_id = window.APP_DATA.applicationID\n        let return_ui_url = redirect_url ? encodeURIComponent(redirect_url) : encodeURIComponent(window.location.href)\n        let url = `/ext/retail-auth/ui/login?application_id=${app_id}&return_ui_url=${return_ui_url}`\n        window.location.replace(url);\n    },\n    openProfile: function (redirect_url) {\n        let app_id = window.APP_DATA.applicationID\n        let return_ui_url = redirect_url ? encodeURIComponent(redirect_url) : encodeURIComponent(window.location.href)\n        let url = `/ext/retail-auth/ui/profile-redirect?application_id=${app_id}&return_ui_url=${return_ui_url}`\n        window.location.replace(url);\n    }\n}\n"},{"name":"JioAds GTM Event","type":"js","sub_type":"inline","compatible_engines":["vue2","react"],"position":"body-bottom","pages":[],"_id":"693bb276d14f005af43d9ce2","content":"(() => {\n  \n  const customCONFIG = {\n    OBSERVER_ROOT_MARGIN: '50px 0px',\n    OBSERVER_THRESHOLD: [0.1, 0.5, 1.0],\n    PERIODIC_CHECK_INTERVAL: 1000,\n    PERIODIC_CHECK_MAX: 60,\n    HIGHLIGHT_DURATION: 2000,\n    BADGE_DURATION: 3000,\n    SLIDE_RECHECK_DEBOUNCE: 100\n  };\n  \n  \n  const customPAGE_TYPES = {\n    HOME: 'home',\n    PLP: 'product-listing',\n    COLLECTION: 'collection-listing',\n    PDP: 'product-description',\n    SEARCH: 'search',\n    CART: 'cart',\n    WISHLIST: 'wishlist',\n    SECTION: 'section',\n    OTHER: 'other'\n  };\n  \n  const customDetectPageType = () => {\n    const pathname = window.location.pathname;\n    const pageTitle = (document.title || '').toLowerCase();\n    const searchParams = new URLSearchParams(window.location.search);\n    \n    // Home page\n    if (pathname === '/' || pathname === '') {\n      return customPAGE_TYPES.HOME;\n    }\n    \n    // PDP - Product Description Page\n    if (pathname.includes('/product/') || pathname.match(/\\/p\\/[^\\/]+$/)) {\n      return customPAGE_TYPES.PDP;\n    }\n    \n    // Search page\n    if (searchParams.has('q') || pathname.includes('/search')) {\n      return customPAGE_TYPES.SEARCH;\n    }\n    \n    // Collection page\n    if (pathname.includes('/collection/') || pathname.includes('/c/')) {\n      return customPAGE_TYPES.COLLECTION;\n    }\n    \n    // PLP - Product Listing Page\n    if (pathname.includes('/products') || pathname.includes('/category/')) {\n      return customPAGE_TYPES.PLP;\n    }\n    \n    // Cart page\n    if (pathname.includes('/cart') || pageTitle.includes('cart')) {\n      return customPAGE_TYPES.CART;\n    }\n    \n    // Wishlist page\n    if (pathname.includes('/wishlist') || pageTitle.includes('wishlist')) {\n      return customPAGE_TYPES.WISHLIST;\n    }\n    \n    // Section page\n    if (pathname.includes('/section/') || pathname.includes('/sections/')) {\n      return customPAGE_TYPES.SECTION;\n    }\n    \n    return customPAGE_TYPES.OTHER;\n  };\n  \n  \n  const customState = {\n    pageType: customDetectPageType(),\n    trackedImpressions: new Set(),\n    trackedClicks: new Set(),\n    trackedAdspotIds: new Set(),\n    trackedEvents: [],\n    eventCounter: 0,\n    adElements: [],\n    observer: null,\n    intervalId: null,\n    startTime: Date.now()\n  };\n  \n  // Console styling\n  const customSTYLES = {\n    header: 'background: linear-gradient(135deg, #E91E63, #9C27B0); color: white; padding: 12px 20px; font-size: 16px; border-radius: 8px; font-weight: bold;',\n    success: 'background: #4CAF50; color: white; padding: 4px 8px; border-radius: 4px; font-weight: bold;',\n    info: 'background: #2196F3; color: white; padding: 4px 8px; border-radius: 4px; font-weight: bold;',\n    warning: 'background: #FF9800; color: white; padding: 4px 8px; border-radius: 4px; font-weight: bold;',\n    error: 'background: #f44336; color: white; padding: 4px 8px; border-radius: 4px; font-weight: bold;',\n    impression: 'background: #2196F3; color: white; padding: 4px 8px; border-radius: 3px; font-weight: bold;',\n    click: 'background: #FF9800; color: white; padding: 4px 8px; border-radius: 3px; font-weight: bold;',\n    pageType: 'background: #9C27B0; color: white; padding: 4px 8px; border-radius: 4px;'\n  };\n  \n  \n  \n  \n  \n  const customExtractUvFromUrl = (url) => {\n    try {\n      const urlParams = new URL(url, window.location.origin).searchParams;\n      return urlParams.get('uv') || '';\n    } catch (e) {\n      const match = /[?&]uv=([^&]+)/.exec(url);\n      return match && match[1] ? match[1] : '';\n    }\n  };\n  \n  const customExtractAdCampaignId = (url) => {\n    const match = /adcampaignid=([^&]+)/.exec(url);\n    return match && match[1] ? match[1] : '';\n  };\n  \n  const customGetPageData = () => {\n    let pincode = '';\n    try { pincode = parseInt(localStorage.getItem('pincode')) || ''; } catch (e) {}\n    \n    const isMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);\n    \n    // Get login status\n    let loginStatus = 'not logged in';\n    try {\n      const customerData = localStorage.getItem('customer_data');\n