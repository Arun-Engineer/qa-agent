.n-toast-container-main {
  position: fixed;
  z-index: var(--ZIndex3, 999);
  display: flex;
  flex-direction: column;
  font-size: calc((16 / var(--BaseFontSize, 10)) * 1rem);
}
.n-toast-container-main .n-toast-wrapper {
  background: var(--ColorSecondaryGrey80, rgba(0, 0, 0, 0.65));
  border-radius: 1.4em;
  color: #ffffff;
  width: calc((250 / var(--BaseFontSize, 10)) * 1rem);
  margin-bottom: calc((10 / var(--BaseFontSize, 10)) * 1rem);
  transition: transform 0.6s ease-in-out;
  min-height: calc((25 / var(--BaseFontSize, 10)) * 1rem);
  display: flex;
  justify-content: space-between;
  padding: calc((12 / var(--BaseFontSize, 10)) * 1rem);
  font-family: var(--PrimaryFont, "NitrozenType", helvetica, arial, sans-serif);
}
@media screen and (max-width: 425px) {
  .n-toast-container-main .n-toast-wrapper {
    width: calc((328 / var(--BaseFontSize, 10)) * 1rem) !important;
  }
}
.n-toast-container-main .n-toast-wrapper .n-toast-left-container {
  display: flex;
  width: 90%;
  gap: 0.5em;
}
.n-toast-container-main .n-toast-wrapper .n-toast-left-container .n-toast-title-container {
  display: flex;
  flex-direction: column;
  gap: 0.3em;
  width: 100%;
}
.n-toast-container-main .n-toast-wrapper .n-toast-left-container .n-toast-header {
  display: inline-block;
  text-overflow: ellipsis;
  width: 90%;
  color: #ffffff;
  font-size: 1em;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 30em;
  user-select: none;
}
.n-toast-container-main .n-toast-wrapper .n-toast-left-container .n-toast-left-image {
  height: 100%;
  object-fit: contain;
  border-radius: 0.6em;
}
.n-toast-container-main .n-toast-wrapper .n-toast-left-container .n-toast-left-image img {
  height: 2em;
  width: 2em;
  border-radius: 0.4em;
}
.n-toast-container-main .n-toast-wrapper .n-toast-right-image {
  object-fit: contain;
  border-radius: 0.6em;
  cursor: pointer;
}
.n-toast-container-main .n-toast-wrapper .n-toast-right-image img {
  height: 2em;
  width: 2em;
  border-radius: 0.4em;
}
.n-toast-container-main .n-toast-wrapper .n-toast-center-align {
  display: flex;
  justify-content: center;
  align-items: center;
}
.n-toast-container-main .n-toast-wrapper .n-toast-body {
  display: flex;
  width: 90%;
  word-break: break-word;
  flex-direction: row;
  color: #ffffff;
  font-size: 0.8em;
}
.n-toast-container-main .n-toast-wrapper .n-toast-space-between {
  justify-content: space-between;
  align-items: center;
}
.n-toast-container-main .n-toast-wrapper-top-center {
  animation: toast-in-center 0.7s;
}
.n-toast-container-main .n-toast-wrapper-top-right {
  animation: toast-in-right 0.7s;
}
.n-toast-container-main .n-toast-wrapper-bottom-right {
  animation: toast-in-right 0.7s;
}
.n-toast-container-main .n-toast-wrapper-bottom-left {
  animation: toast-in-left 0.7s;
}
.n-toast-container-main .n-toast-wrapper-top-left {
  animation: toast-in-left 0.7s;
}

.n-toast-top-right {
  top: calc((50 / var(--BaseFontSize, 10)) * 1rem);
  right: calc((50 / var(--BaseFontSize, 10)) * 1rem);
  transition: transform 0.6s ease-in-out;
  animation: toast-in-right 0.7s;
}

.n-toast-bottom-right {
  bottom: calc((50 / var(--BaseFontSize, 10)) * 1rem);
  right: calc((50 / var(--BaseFontSize, 10)) * 1rem);
  transition: transform 0.6s ease-in-out;
  animation: toast-in-right 0.7s;
}

.n-toast-top-center {
  top: 10%;
  left: 50%;
  transform: translateX(-50%);
}

.n-toast-top-left {
  top: calc((50 / var(--BaseFontSize, 10)) * 1rem);
  left: calc((50 / var(--BaseFontSize, 10)) * 1rem);
  transition: transform 0.6s ease-in;
  animation: toast-in-left 0.7s;
}

.n-toast-bottom-left {
  bottom: calc((50 / var(--BaseFontSize, 10)) * 1rem);
  left: calc((50 / var(--BaseFontSize, 10)) * 1rem);
  transition: transform 0.6s ease-in;
  animation: toast-in-left 0.7s;
}

@keyframes toast-in-right {
  from {
    transform: translateX(100%);
  }
  to {
    transform: translateX(0);
  }
}
@keyframes toast-in-left {
  from {
    transform: translateX(-100%);
  }
  to {
    transform: translateX(0);
  }
}
@keyframes toast-in-center {
  from {
    transform: translateY(50%);
  }
  to {
    transform: translateY(0);
  }
