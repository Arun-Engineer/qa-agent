# AI QA Agent v5 - Environment Configuration
# Copy this to .env and fill in real values

# API Security
API_SECRET_KEY=change-me-to-a-random-string
API_RATE_LIMIT_PER_MINUTE=60

# Anthropic (for Phase 3+)
ANTHROPIC_API_KEY=sk-ant-xxx

# Database (for Phase 4+)
DATABASE_URL=postgresql://qa:password@localhost:5432/qa_agent
QDRANT_URL=http://localhost:6333
NEO4J_URI=bolt://localhost:7687
REDIS_URL=redis://localhost:6379

# Integrations (for Phase 5+)
ADO_ORG_URL=https://dev.azure.com/your-org
ADO_PAT=xxx
SLACK_BOT_TOKEN=xoxb-xxx
