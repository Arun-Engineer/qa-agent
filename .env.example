# QA Agent v5 — copy to .env and fill values. NEVER commit .env.
APP_ENV=sit
BASE_DOMAIN=localhost
SESSION_SECRET=CHANGE-ME-IN-PRODUCTION
DEFAULT_TENANT=local

# Auth
API_SECRET_KEY=
RESET_SECRET=

# LLM
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Database
DATABASE_URL=sqlite:///./data/app.db

# Vector store (optional)
RAG_ENABLED=1
CHROMA_DIR=data/chroma

# Rate limiting
API_RATE_LIMIT_PER_MINUTE=60
# ANTHROPIC_API_KEY=
# LLM_PROVIDER=openai

# ── Orchestrator (MVP) ──
QA_MAX_RETRIES=3
QA_STEP_TIMEOUT=120
QA_PLAN_TIMEOUT=60
QA_DISABLE_RECON=0
FORCE_REGEN_TESTS=0
ARTIFACTS_DIR=data/logs

# Secret admin panel URL key (change this!)
ADMIN_SECRET_KEY=nugw4yjj9_v90fVmBvIRk-Nk-rwEdm68

# Platform God — untouchable admin account
PLATFORM_GOD_EMAIL=musicstarq@gmail.com
